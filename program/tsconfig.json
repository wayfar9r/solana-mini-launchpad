{
  "compilerOptions": {
    "types": ["mocha", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2024"],
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "esModuleInterop": true,
  },
  "ts-node": {
    "moduleTypes": {
      "**/*.ts": "cjs"
    }
  }
}
