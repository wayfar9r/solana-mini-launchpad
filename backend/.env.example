# RPC: localnet (make backend) или devnet (make backend-devnet подставит свои)
# Localnet (нужен запущенный make validator):
SOLANA_RPC_HTTP=http://127.0.0.1:8899
SOLANA_RPC_WS=ws://127.0.0.1:8900
# Devnet (для make backend-devnet можно не задавать — подставятся автоматически):
# SOLANA_RPC_HTTP=https://api.devnet.solana.com
# SOLANA_RPC_WS=wss://api.devnet.solana.com

# Program IDs (match program/Anchor.toml localnet)
ORACLE_PROGRAM_ID=4cuvLFFqhaKnTHfeq2FtTUvgudRSe7wq982fA9PBUqBU
MINTER_PROGRAM_ID=E5erGzaxgCwHqH7RjLXLGWziXj8CXpyN7zW6BRodfFnE

# Oracle state PDA: run from program/ after anchor build:
#   node -e "const a=require('@coral-xyz/anchor');const [p]=a.web3.PublicKey.findProgramAddressSync([Buffer.from('oracle_state')],new a.web3.PublicKey(process.env.ORACLE_PROGRAM_ID||'88GBkKvZbhtTcXy2tpwHQSVxHqPqurQbjKW1nLzER84c'));console.log(p.toBase58());"
# Or copy from migration output after: cd program && anchor migrate
ORACLE_STATE_PUBKEY=<PDA from "oracle_state" seed>

# Keypair that is the oracle admin (same as deploy wallet)
BACKEND_KEYPAIR_PATH=~/.config/solana/id.json

# Price: leave MOCK_PRICE unset to use live SOL/USD from Binance (default URL below).
# If MOCK_PRICE is set, the oracle will always show that value (e.g. 125000000 = 125 USD) — for local/testing only.
# Optional overrides:
PRICE_POLL_INTERVAL_SEC=600
# MOCK_PRICE=120000000
# PRICE_API_URL=https://api.binance.com/api/v3/ticker/price?symbol=SOLUSDT
